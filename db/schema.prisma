// Abacus — Prisma schema
// Feature 003 lands the first real model (User). JWT-only sessions; no Auth.js adapter tables.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
