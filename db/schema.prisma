// Abacus — Prisma schema
// Feature 003 lands the first real model (User). JWT-only sessions; no Auth.js adapter tables.
// Feature 004 adds Account + AccountType (the first money-touching domain model).
// Feature 006 adds Category + CategoryKind (the second domain model; non-money-touching).
// Feature 007 adds Transaction + TransactionType (the third domain model; the keystone money-correctness feature).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  accounts     Account[]     // back-relation from feature 004
  categories   Category[]    // back-relation from feature 006
  transactions Transaction[] // back-relation from feature 007
}

model Account {
  id              String      @id @default(cuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String      @db.VarChar(80)
  type            AccountType
  currency        String      @db.Char(3)
  startingBalance Decimal     @db.Decimal(20, 8)
  archivedAt      DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  transactions Transaction[] // back-relation from feature 007

  @@index([userId])
  @@index([userId, archivedAt])
}

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT
  CASH
  INVESTMENT
  OTHER
}

model Category {
  id         String       @id @default(cuid())
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId   String?
  parent     Category?    @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children   Category[]   @relation("CategoryHierarchy")
  name       String       @db.VarChar(80)
  kind       CategoryKind
  color      String       @db.VarChar(32)
  icon       String       @db.VarChar(64)
  archivedAt DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  transactions Transaction[] // back-relation from feature 007

  @@index([userId])
  @@index([userId, archivedAt])
  @@index([userId, parentId])
}

enum CategoryKind {
  INCOME
  EXPENSE
}

// ---------------------------------------------------------------------------
// Feature 007 — Transaction + TransactionType
// ---------------------------------------------------------------------------

model Transaction {
  id              String          @id @default(cuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId       String
  account         Account         @relation(fields: [accountId], references: [id], onDelete: Restrict)
  categoryId      String?
  category        Category?       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  // date: calendar-day only (Postgres DATE). Normalized to UTC midnight at the Zod boundary
  // (normalizeToUtcDay in lib/transactions/dates.ts). @db.Date strips the time component at
  // the storage layer. If @db.Date causes Prisma 7 serialization quirks (date returned with
  // local-TZ time component), fall back to DateTime without @db.Date — the normalizeToUtcDay
  // boundary helper already enforces UTC midnight on the way in. (data-model.md §Date handling)
  date            DateTime        @db.Date
  // amount: signed Decimal. INCOME > 0; EXPENSE < 0; TRANSFER: source < 0, dest > 0.
  // Sign is load-bearing; constitution Principle I; sign-must-match-type enforced at Zod boundary.
  amount          Decimal         @db.Decimal(20, 8)
  currency        String          @db.Char(3)
  type            TransactionType
  payee           String?         @db.VarChar(120)
  notes           String?         @db.VarChar(500)
  // transferGroupId: server-generated cuid shared by both TRANSFER legs; null for INCOME/EXPENSE.
  // The two-leg invariant is enforced structurally via prisma.$transaction (research.md R3, R4).
  transferGroupId String?
  archivedAt      DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([userId, date])
  @@index([userId, accountId, date])
  @@index([userId, categoryId])
  @@index([userId, transferGroupId])
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}
