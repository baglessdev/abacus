# Database
# Local: the docker-compose Postgres.
# Production (Vercel + Neon): Neon's POOLED connection string (host contains "-pooler").
DATABASE_URL="postgresql://abacus:abacus_dev_password@localhost:5432/abacus?schema=public"

# Direct connection used by Prisma migrate during build.
# Local: same as DATABASE_URL.
# Production (Vercel + Neon): Neon's DIRECT connection string (host WITHOUT "-pooler").
# Not yet enforced by lib/env.ts; required by deploy/vercel-neon.md Step 2.
DIRECT_URL="postgresql://abacus:abacus_dev_password@localhost:5432/abacus?schema=public"

# Auth.js — both required from feature 003 onward.
# Generate AUTH_SECRET with: openssl rand -base64 32 (must be ≥32 chars).
# On Vercel: set AUTH_URL for Production only — leave unset on Preview so NextAuth
# falls back to the request host (each preview deploy has its own URL).
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# App
NODE_ENV="development"
